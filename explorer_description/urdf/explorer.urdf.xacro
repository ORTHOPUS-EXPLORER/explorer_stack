<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="explorer">
  <xacro:arg name="use_POC2" default="false" />
  <xacro:arg name="simulation" default="false" />
    <!-- if Simulation-->
    <xacro:arg name="use_ignition" default="true" />
    <!-- else -->
    <xacro:arg name="can_port" default="vxcan1" />
    <xacro:arg name="host_id" default="45" />
    <xacro:arg name="rt_stream_rate" default="250" />
    <xacro:arg name="aux_stream_rate" default="50" />
    <!-- endif -->
  

  <xacro:include filename="$(find gripper_pincette)/description/urdf/gripper_pincette_description.urdf.xacro"/>

  <!-- create link fixed to the "world" -->
  <link name="world"/>

  <link name="camera_explorer"/>

  <!-- base_joint fixes base_link to the environment -->
  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <xacro:unless value="$(arg use_POC2)">
    <!-- Import explorer macro -->
    <xacro:include filename="$(find explorer_description)/urdf/explorer_POC1_description.urdf.xacro"/>
    <joint name="joint_6" type="revolute">
      <parent link="link_5"/>
      <child link="structure"/>
      <origin xyz="0 0.090 0.083" rpy="0 ${(65*pi)/180} ${pi/2}"/>
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="10"/>
    </joint>
    <xacro:explorer_POC1_description/>
  </xacro:unless>
  <xacro:if value="$(arg use_POC2)">
    <!-- Import explorer macro -->
    <xacro:include filename="$(find explorer_description)/urdf/explorer_POC2_description.urdf.xacro"/>

    <joint name="joint_6" type="revolute">
      <parent link="link_5"/>
      <child link="structure"/>
      <origin xyz="0 0.1555 -0.027" rpy="${pi/2} ${pi} ${pi}"/>
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-2.97" upper="2.97" velocity="10"/>
    </joint>
    <xacro:explorer_POC2_description/>
  </xacro:if>

  <joint name="joint-ft_frame" type="fixed">
    <parent link="structure"/>
    <child link="ft_frame"/>
    <origin xyz="0.011 0 0.15" rpy="0 0 0"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="structure"/>
    <child link="camera_explorer"/>
    <origin xyz="0.011 0 0.105" rpy="0 ${-pi/2} 0"/>
  </joint>

  <joint name="joint-tool" type="fixed">
    <parent link="ft_frame"/>
    <child link="tool0"/>
    <origin xyz="-0.011 0 0" rpy="0 ${-pi/2} 0"/>
  </joint>

  <xacro:gripper_pincette/>

  <!-- Import explorer ros2_control description -->
  <xacro:if value="$(arg simulation)">
    <xacro:include filename="$(find explorer_description)/ros2_control/explorer_simulation.ros2_control.xacro" />
    <xacro:explorer_ros2_control name="explorer" use_ignition="$(arg use_ignition)" />
  </xacro:if>
  <xacro:unless value="$(arg simulation)">
    <xacro:include filename="$(find explorer_description)/ros2_control/explorer_actuators.ros2_control.xacro" />
    <xacro:explorer_ros2_control 
      name="explorer" 
      can_port="$(arg can_port)" 
      host_id="$(arg host_id)" 
      rt_stream_rate="$(arg rt_stream_rate)" 
      aux_stream_rate="$(arg aux_stream_rate)" 
    />
  </xacro:unless>
</robot>
