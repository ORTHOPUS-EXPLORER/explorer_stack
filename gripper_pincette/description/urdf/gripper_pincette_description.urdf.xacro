<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="gripper_pincette">

  <!-- helper macro -->
  <xacro:include filename="$(find gripper_pincette)/description/urdf/inc/create_link.xacro"/>    

  <xacro:create_link
      link_name="structure"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="structure"
      xyz_mass="0.015 0 0.05"
      mass="0.15"
      ixx="0.0003368"
      ixy="0"
      ixz="0"
      iyy="0.00023445"
      iyz="0"
      izz="0.00021125"
  />

  <xacro:create_link
      link_name="motor"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="motor"
      xyz_mass="-0.015 0 0.03"
      mass="0.15"
      ixx="0.0000578125"
      ixy="0"
      ixz="0"
      iyy="0.0000890125"
      iyz="0"
      izz="0.0000712"
  />

  <xacro:create_link
      link_name="palm_top_shell"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="palm_top_shell"
      xyz_mass="-0.03 0 0.002"
      mass="0.01"
      ixx="0.0000099075"
      ixy="0"
      ixz="0"
      iyy="0.00000462833"
      iyz="0"
      izz="0.00001416083"
  />

  <xacro:create_link
      link_name="right_finger_first_phalanx"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="right_finger_first_phalanx"
      xyz_mass="0.02 -0.02 0.004"
      mass="0.02"
      ixx="0.00000267533"
      ixy="0.00000142249"
      ixz="0"
      iyy="0.00000988018"
      iyz="0"
      izz="0.00001059"
  />

  <xacro:create_link
      link_name="right_external_rod"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="external_rod"
      xyz_mass="0.015 0.01 0"
      mass="0.005"
      ixx="1.17274274e-7"
      ixy="-6.77083335e-8"
      ixz="0"
      iyy="0.00000138022"
      iyz="0"
      izz="0.00000154166"
  />

  <xacro:create_link
      link_name="right_finger_last_phalanx"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="finger_last_phalanx"
      xyz_mass="0.015 0.01 0"
      mass="0.015"
      ixx="0.00000289"
      ixy="0"
      ixz="0"
      iyy="0.00000457"
      iyz="0"
      izz="0.00000457"
  />

  <xacro:create_link
      link_name="left_finger_first_phalanx"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="left_finger_first_phalanx"
      xyz_mass="0.02 0.02 0.004"
      mass="0.02"
      ixx="0.00000267533"
      ixy="-0.00000142249"
      ixz="0"
      iyy="0.00000988018"
      iyz="0"
      izz="0.00001059"
  />

  <xacro:create_link
      link_name="left_external_rod"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="external_rod"
      xyz_mass="0.015 0.01 0"
      mass="0.005"
      ixx="1.17274274e-7"
      ixy="-6.77083335e-8"
      ixz="0"
      iyy="0.00000138022"
      iyz="0"
      izz="0.00000154166"
  />

  <xacro:create_link
      link_name="left_finger_last_phalanx"
      xyz_offset="0 0 0"
      rpy_offset="0 0 0"
      mesh_package="gripper_pincette"
      mesh_name="finger_last_phalanx"
      xyz_mass="0.015 0.01 0"
      mass="0.015"
      ixx="0.00000289"
      ixy="0"
      ixz="0"
      iyy="0.00000457"
      iyz="0"
      izz="0.00000457"
  />

  <joint name="structure_motor" type="fixed">
    <parent link="structure"/>
    <child link="motor"/>
    <origin xyz="0.009 0 0.0825" rpy="0 -1.57 0"/>
  </joint>

  <joint name="structure_palm" type="fixed">
    <parent link="structure"/>
    <child link="palm_top_shell"/>
    <origin xyz="-0.002 0 0.101" rpy="0 -1.57 0"/>
  </joint>

  <joint name="right_finger_joint" type="revolute">
    <parent link="structure"/>
    <child link="right_finger_first_phalanx"/>
    <origin xyz="0.015 -0.038 0.1015" rpy="0 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="0.0" upper="1.05" velocity="2.5"/>
  </joint>

  <joint name="right_external_rod_joint" type="revolute">
    <mimic joint="right_finger_joint" multiplier="-1" offset="0"/>
    <parent link="structure"/>
    <child link="right_external_rod"/>
    <origin xyz="0.012 -0.054 0.1069" rpy="3.14 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-1.05" upper="0.0" velocity="2.5"/>
  </joint>

  <joint name="right_fingertip_joint" type="revolute">
    <mimic joint="right_finger_joint" multiplier="-1" offset="0"/>
    <parent link="right_external_rod"/>
    <child link="right_finger_last_phalanx"/>
    <origin xyz="0.0433 0.025 0" rpy="3.14 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-1.05" upper="0.0" velocity="2.5"/>
  </joint>

  <joint name="left_finger_joint" type="revolute">
    <mimic joint="right_finger_joint" multiplier="-1" offset="0"/>
    <parent link="structure"/>
    <child link="left_finger_first_phalanx"/>
    <origin xyz="0.015 0.038 0.1015" rpy="0 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-1.05" upper="0.0" velocity="2.5"/>
  </joint>

  <joint name="left_external_rod_joint" type="revolute">
    <mimic joint="right_finger_joint" multiplier="-1" offset="0"/>
    <parent link="structure"/>
    <child link="left_external_rod"/>
    <origin xyz="0.012 0.054 0.1069" rpy="0 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-1.05" upper="0.0" velocity="2.5"/>
  </joint>

  <joint name="left_fingertip_joint" type="revolute">
    <mimic joint="right_finger_joint" multiplier="-1" offset="0"/>
    <parent link="left_external_rod"/>
    <child link="left_finger_last_phalanx"/>
    <origin xyz="0.0433 0.025 0" rpy="3.14 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-1.05" upper="0.0" velocity="2.5"/>
  </joint>



</xacro:macro>

</robot>