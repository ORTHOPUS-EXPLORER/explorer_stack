<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="explorer">
  <xacro:arg name="use_ignition" default="false" />
  <xacro:arg name="use_actuator_interface" default="false" />

  <!-- Import explorer macro -->
  <xacro:include filename="$(find ros2_control_explorer)/description/urdf/explorer_old_description.urdf.xacro"/>
  <xacro:include filename="$(find gripper_pincette)/description/urdf/gripper_pincette_description.urdf.xacro"/>

  <!-- create link fixed to the "world" -->
  <link name="world"/>

  <!-- base_joint fixes base_link to the environment -->
  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="structure"/>
    <origin xyz="0 0.090 0.083" rpy="${-(65*pi)/180} 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="${-pi}" upper="${pi}" velocity="2.5"/>
  </joint>

  <joint name="joint-ft_frame" type="fixed">
    <parent link="structure"/>
    <child link="ft_frame"/>
    <origin xyz="0.011 0 0.15" rpy="0 0 0"/>
  </joint>


  <joint name="joint-tool" type="fixed">
    <parent link="ft_frame"/>
    <child link="tool0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:explorer_old_description/>
  <xacro:gripper_pincette/>

  <!-- Import explorer ros2_control description -->
  <xacro:unless value="$(arg use_actuator_interface)">
    <xacro:include filename="$(find ros2_control_explorer)/description/ros2_control/explorer.ros2_control.xacro" />
    <xacro:explorer_ros2_control name="explorer" use_ignition="$(arg use_ignition)"/>
  </xacro:unless>
  <xacro:if value="$(arg use_actuator_interface)">
    <xacro:include filename="$(find ros2_control_explorer)/description/ros2_control/explorer_actuators.ros2_control.xacro" />
    <xacro:explorer_ros2_control name="explorer" use_ignition="$(arg use_ignition)" />
  </xacro:if>

  <xacro:if value="$(arg use_ignition)">
    <!-- Import Gazebo definitions + plugin -->
    <xacro:include filename="$(find ros2_control_explorer)/description/gazebo/explorer.gazebo.xacro" />
    <xacro:explorer_gazebo/>
  </xacro:if>

</robot>
